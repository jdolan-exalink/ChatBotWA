# ============================================
# CONFIGURACIÓN DE CLÍNICA WHATSAPP BOT
# ============================================
# Copiar esto a .env y completar con tus valores

# ============================================
# WHATSAPP / WAHA
# ============================================
WAHA_API_KEY=your-api-key-here
WAHA_SESSION=default
WAHA_URL=http://waha:3000

# ============================================
# BASE DE DATOS
# ============================================
# SQLite (por defecto, simplifica deployment)
DATABASE_URL=sqlite:///./clinic_bot.db

# O PostgreSQL (mejor para producción)
# DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/clinic_bot

# ============================================
# SEGURIDAD
# ============================================
# Cambiar esto en producción! Generar con:
# python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-in-production

# ADMIN PASSWORD (usar en primera instalación)
ADMIN_PASSWORD=admin123

# Timeout de sesión admin en segundos
ADMIN_IDLE_TIMEOUT_SEC=900

# ============================================
# CONFIGURACIÓN DEL BOT
# ============================================
# Nombre que aparece en toda la interfaz
SOLUTION_NAME=Clínica

# Modo debug del backend (logs detallados). Por defecto desactivado.
DEBUG_MODE=false

# ============================================
# IA - OLLAMA
# ============================================
OLLAMA_URL=http://10.1.1.39:11434
OLLAMA_MODEL=lfm2:latest

# ============================================
# EMAIL (Opcional - para alertas)
# ============================================
# Seguir esta guía: https://developers.google.com/gmail/api/quickstart/python
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
ALERT_EMAIL_TO=tu-email@example.com
ALERT_EMAIL_FROM=

# ============================================
# N8N (Opcional - para webhooks)
# ============================================
N8N_EVENT_WEBHOOK=

# ============================================
# PUERTO (si cambias, también actualizar docker-compose.yml)
# ============================================
PORT=8088

# ============================================
# CHAT TIMEOUT (segundos de inactividad antes de resetear state)
# ============================================
CHAT_IDLE_RESET_SEC=180
